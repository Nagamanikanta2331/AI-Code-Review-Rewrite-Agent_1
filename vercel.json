{
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/app", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "buildCommand": "",
  "outputDirectory": ".",
  "ignoreCommand": "exit 0"
}
